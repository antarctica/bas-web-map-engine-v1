{
  "builders": [
    {
      "boot_command": [
        "<up><wait><tab> text ks=http://{{ .HTTPIP }}:{{ .HTTPPort }}/ks.cfg<enter><wait>"
      ],
      "boot_wait": "10s",
      "http_directory": "preseed",
      "virtualbox_version_file": ".vbox_version",
      "guest_additions_path": "VBoxGuestAdditions_{{.Version}}.iso",
      "guest_os_type": "RedHat_64",
      "hard_drive_interface": "sata",
      "headless": true,
      "iso_checksum": "{{user `iso_checksum`}}",
      "iso_checksum_type": "{{user `iso_checksum_type`}}",
      "iso_url": "{{user `mirror`}}/{{user `mirror_directory`}}/{{user `iso_name`}}",
      "shutdown_command": "echo 'vagrant' | sudo -S /sbin/halt -h -p",
      "ssh_port": 22,
      "ssh_wait_timeout": "10000s",
      "ssh_username": "root",
      "ssh_password": "password",
      "disk_size": "{{user `disk_size`}}",
      "vboxmanage": [
        [
          "modifyvm",
          "{{.Name}}",
          "--memory",
          "{{ user `memory` }}"
        ],
        [
          "modifyvm",
          "{{.Name}}",
          "--cpus",
          "{{ user `cpus` }}"
        ]
      ],
      "vm_name": "{{user `template`}}-{{isotime \"2006-01-02\"}}",
      "format": "ova",
      "output_directory": "artefacts/ovas/{{user `template`}}-virtualbox",
      "type": "virtualbox-iso"
    }
  ],
  "provisioners": [
    {
      "environment_vars": [
        "TEMPLATE_NAME={{user `template`}}",
        "TEMPLATE_VERSION={{isotime \"2019-08-26\"}}",
        "APP_OS_GEOWEB_PASSWORD={{user `app_os_geoweb_password`}}",
        "APP_TOMCAT_MANAGER_PASSWORD={{user `app_tomcat_manager_password`}}",
        "APP_DATABASE_POSTGRES_PASSWORD={{user `app_database_postgres_password`}}"
      ],
      "expect_disconnect": true,
      "scripts": [
        "setup-os.sh",
        "setup-app-stack.sh"
      ],
      "type": "shell"
    },
    {
      "expect_disconnect": true,
      "inline": ["mkdir -p /var/geoserver/data"],
      "type": "shell"
    },
    {
      "source": "../../geoserver/data/",
      "destination": "/var/geoserver/data/",
      "type": "file"
    },
    {
      "source": "../../resources/application.properties",
      "destination": "/tmp/application.properties",
      "type": "file"
    },
    {
      "source": "../../src/main/webapp/WEB-INF/sql/table_creation/webmap_tables.sql",
      "destination": "/tmp/app-structure.sql",
      "type": "file"
    },
    {
      "source": "../../src/main/webapp/WEB-INF/sql/table_creation/webmap_auth_tables.sql",
      "destination": "/tmp/app-auth-structure.sql",
      "type": "file"
    },
    {
      "source": "../../src/main/webapp/WEB-INF/sql/table_population/standalone/test-data.sql",
      "destination": "/tmp/app-data.sql",
      "type": "file"
    },
    {
      "environment_vars": [
        "APP_DATABASE_APP_PASSWORD={{user `app_database_app_password`}}",
        "APP_GEOSERVER_MASTER_PASSWORD={{user `app_geoserver_master_password`}}",
        "APP_GEOSERVER_ADMIN_PASSWORD={{user `app_geoserver_admin_password`}}"
      ],
      "scripts": [
        "setup-app.sh",
        "cleanup-os.sh"
      ],
      "type": "shell"
    },
    {
      "scripts": [
        "setup-vagrant.sh",
        "cleanup-os-iso.sh"
      ],
      "type": "shell",
      "only": ["virtualbox-iso"]
    }
  ],
  "post-processors": [
    {
      "keep_input_artifact": true,
      "output": "artefacts/vagrant-bas-boxes/{{ user `template`}}-{{.Provider}}-{{isotime \"2006-01-02\"}}.box",
      "type": "vagrant",
      "only": ["virtualbox-iso"]
    },
    {
      "inline": [
        "chmod +r ./artefacts/ovas/web-map-engine-standalone-virtualbox/web-map-engine-standalone-*.ova artefacts/vagrant-bas-boxes/web-map-engine-standalone-virtualbox-*.box",
        "scp ./artefacts/ovas/web-map-engine-standalone-virtualbox/web-map-engine-standalone-*.ova bsl-repoa.nerc-bas.ac.uk:/var/repo/magic/v1/projects/web-map-engine/latest/ova/",
        "scp ./artefacts/vagrant-bas-boxes/web-map-engine-standalone-virtualbox-*.box bsl-repoa.nerc-bas.ac.uk:/var/repo/magic/v1/projects/web-map-engine/latest/vagrant/"
      ],
      "type": "shell-local",
      "only": ["virtualbox-iso"]
    }
  ],
  "variables": {
    "template": "web-map-engine-standalone",
    "http_proxy": "{{env `http_proxy`}}",
    "https_proxy": "{{env `https_proxy`}}",
    "no_proxy": "{{env `no_proxy`}}",
    "mirror": "http://mirrors.kernel.org/centos",
    "mirror_directory": "7.6.1810/isos/x86_64",
    "iso_checksum": "6d44331cc4f6c506c7bbe9feb8468fad6c51a88ca1393ca6b8b486ea04bec3c1",
    "iso_checksum_type": "sha256",
    "iso_name": "CentOS-7-x86_64-DVD-1810.iso",
    "cpus": "1",
    "memory": "4096",
    "disk_size": "65536",
    "app_os_geoweb_password": "password",
    "app_tomcat_manager_password": "password",
    "app_geoserver_master_password": "password ",
    "app_geoserver_admin_password": "password ",
    "app_database_postgres_password": "password",
    "app_database_app_password": "password"
  },
  "sensitive-variables": [
    "app_os_geoweb_password",
    "app_tomcat_manager_password",
    "app_database_postgres_password",
    "app_database_app_password"
  ]
}
